# ─────────────────────────────────────────────────────────────────────────────
# Optimus Training API — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ─── Entornos virtuales ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
virtualenv/

# ─── Python bytecode ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ─── Distribución / packaging ────────────────────────────────────────────────
build/
dist/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ─── Variables de entorno (nunca subir credenciales) ─────────────────────────
.env
.env.local
.env.*.local
.env.dev
.env.staging
.env.prod
# .env.example sí se sube — es la plantilla pública

# ─── Base de datos locales ────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
test.db

# ─── Testing ──────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.hypothesis/
nosetests.xml
coverage.xml
*.cover
junit*.xml

# ─── Uploads de usuarios (fotos reales no van al repo) ───────────────────────
app/uploads/profile_pictures/*
!app/uploads/profile_pictures/.gitkeep
# Si tienes otras carpetas de uploads en el futuro, agrégalas aquí:
# app/uploads/documents/*
# !app/uploads/documents/.gitkeep

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/
*.out

# ─── Cache ────────────────────────────────────────────────────────────────────
.cache/
*.cache
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# ─── Archivos temporales ─────────────────────────────────────────────────────
*.tmp
*.temp
.tmp/
temp/

# ─── IDEs y editores ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.sublime-project
.sublime-workspace

# ─── Sistema operativo ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Herramientas de profiling / debug ───────────────────────────────────────
*.prof
*.lprof
profile_output/

# ─── Alembic ──────────────────────────────────────────────────────────────────
# Los archivos .py de versiones SÍ se suben (son el historial de migraciones)
# Solo ignoramos el bytecode compilado dentro de migrations/
migrations/__pycache__/
migrations/versions/__pycache__/

